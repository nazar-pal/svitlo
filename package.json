{
  "name": "svitlo",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "dev": "EXPO_PUBLIC_APP_VARIANT=development npx expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "auth:generate": "bunx auth@latest generate --config src/data/server/auth.ts --output src/data/server/db-schema/auth.ts --yes",
    "auth:secret": "bunx auth@latest secret",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,md}\"",
    "flt": "npm run format && npm run lint && npm run typecheck"
  },
  "dependencies": {
    "@azure/core-asynciterator-polyfill": "^1.0.2",
    "@better-auth/expo": "^1.5.5",
    "@expo/ui": "~55.0.2",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@neondatabase/serverless": "^1.0.2",
    "@op-engineering/op-sqlite": "^15.2.6",
    "@powersync/drizzle-driver": "^0.7.3",
    "@powersync/op-sqlite": "^0.9.3",
    "@powersync/react-native": "^1.32.0",
    "@react-navigation/bottom-tabs": "^7.7.3",
    "@react-navigation/drawer": "^7.7.2",
    "@react-navigation/elements": "^2.8.1",
    "@react-navigation/native": "^7.1.28",
    "@shopify/flash-list": "2.0.2",
    "@t3-oss/env-core": "^0.13.10",
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "^11.12.0",
    "@trpc/server": "^11.12.0",
    "@trpc/tanstack-react-query": "^11.12.0",
    "better-auth": "^1.5.5",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "expo": "~55.0.5",
    "expo-apple-authentication": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.16",
    "expo-device": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.8",
    "expo-haptics": "^55.0.8",
    "expo-image": "~55.0.6",
    "expo-linking": "~55.0.7",
    "expo-network": "~55.0.8",
    "expo-router": "~55.0.5",
    "expo-secure-store": "~55.0.8",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.9",
    "expo-web-browser": "~55.0.9",
    "heroui-native": "^1.0.0-rc.4",
    "jose": "^6.2.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-controller": "^1.20.7",
    "react-native-mmkv": "^4.2.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.3",
