# ──────────────────────────────────────────────────────────────────────────────
# Environment variables for Svitlo
#
# Required in ALL environments (development, preview, production):
#   DATABASE_URL, BETTER_AUTH_SECRET, POWERSYNC_URL, POWERSYNC_PRIVATE_KEY
#
# Required in preview & production only:
#   BETTER_AUTH_URL, EXPO_PUBLIC_API_URL, EXPO_PUBLIC_APP_VARIANT
#
# In development these are omitted — the app derives API origins automatically
# from the Expo dev server host (works on simulators and physical devices).
# ──────────────────────────────────────────────────────────────────────────────

# ── Always required ──────────────────────────────────────────────────────────

# Neon Postgres connection string (used by Drizzle and Better Auth)
DATABASE_URL=postgresql://user:password@your-neon-endpoint-pooler.neon.tech/neondb?sslmode=require

# Secret used to sign auth tokens (generate with: npm run auth:secret)
BETTER_AUTH_SECRET=replace-with-output-from-npm-run-auth-secret

# Apple Sign In — no env vars needed. Native iOS auth uses bundle identifiers
# configured in the audience array in src/data/server/auth.ts.

# PowerSync Cloud
POWERSYNC_URL=https://your-instance.powersync.journeyapps.com
# HMAC-SHA256 shared secret for signing PowerSync JWTs (min 32 chars).
# Generate with: openssl rand -base64 32
# The same key must be base64url-encoded and entered in the PowerSync dashboard.
POWERSYNC_PRIVATE_KEY=replace-with-a-256-bit-secret-min-32-chars

# ── Preview & production only ────────────────────────────────────────────────
# Omit these in development — they are derived from the Expo dev server.

# The public URL where the Better Auth server is reachable
# BETTER_AUTH_URL=https://your-eas-hosting-domain.example.com

# The public API origin used by native clients (iOS builds)
# EXPO_PUBLIC_API_URL=https://your-eas-hosting-domain.example.com

# Build variant — determines app name suffix and bundle identifier
# EXPO_PUBLIC_APP_VARIANT=preview   # or: production
